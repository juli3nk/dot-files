#!/usr/bin/env bash

# 26.05 sort (mai 2026)
#  ↓
# Attendre 1-2 semaines (stabilisation)
#  ↓
# Lire les release notes
#  ↓
# Tester en build
#  ↓
# Upgrade en boot (pas switch)
#  ↓
# Reboot et vérifier

set -euo pipefail

# Configuration
# FLAKE_DIR="${FLAKE_DIR:-$HOME/nixos-config}"
FLAKE_DIR="/etc/nixos"  # Your flake is in /etc/nixos
HOSTNAME_CURRENT="$(hostname)"
HOSTNAME="${1:-$(hostname)}"
NIXOS_VERSION=""
UPGRADE_MODE=false
NOTIFY=true

# Couleurs
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m'

log() {
    echo -e "${GREEN}[$(date '+%Y-%m-%d %H:%M:%S')]${NC} $*"
}
error() {
    echo -e "${RED}[ERROR]${NC} $*" >&2
    [[ $NOTIFY == true ]] && notify-send -u critical "NixOS Update Failed" "$1"
    exit 1
}
warn() {
    echo -e "${YELLOW}[WARN]${NC} $*"
}
info() {
    echo -e "${BLUE}[INFO]${NC} $*"
}

show_help() {
    echo -e "${BLUE}nixos-update${NC} - NixOS Update Script

${GREEN}Usage:${NC}
  nixos-update [HOSTNAME] [OPTIONS]
  nixos-update --upgrade <version> [HOSTNAME]

${GREEN}Arguments:${NC}
  HOSTNAME              Machine to update (default: current hostname)

${GREEN}Options:${NC}
  --upgrade VERSION     Upgrade NixOS to specified version (e.g., 25.05, 25.11)
  -h, --help            Show this help message

${GREEN}Examples:${NC}
  nixos-update                    # Update current machine
  nixos-update laptop1            # Update laptop1
  nixos-update --upgrade 25.05    # Upgrade current machine to 25.05
  nixos-update --upgrade 25.05 srv1  # Upgrade srv1 to 25.05

${GREEN}Version format:${NC}
  YY.MM (e.g., 25.05, 26.05) - Stable releases only"

    exit 0
}

parse_args() {
    while [[ $# -gt 0 ]]; do
        case $1 in
            --upgrade)
                UPGRADE_MODE=true
                NIXOS_VERSION="$2"
                shift 2
                ;;
            --notify)
                NOTIFY=true
                shift
                ;;
            --no-notify)
                NOTIFY=false
                shift
                ;;
            ;;
            -h|--help)
                show_help
                ;;
            *)
                HOSTNAME="$1"
                shift
                ;;
        esac
    done
}

validate_version() {
    local version="$1"
    
    # Check if version is empty
    [[ -z "$version" ]] && error "Version cannot be empty"
    
    # Reject "unstable"
    [[ "$version" == "unstable" ]] && error "Unstable version is not allowed. Please use a stable release version (YY.MM format)"
    
    # Validate format: YY.MM for stable releases (YY must start with 2-9)
    if [[ ! "$version" =~ ^[2-9]{1}[0-9]{1}\.[0-9]{2}$ ]]; then
        error "Invalid version format: ${version}\nExpected format: YY.MM (e.g., 25.05, 26.05) where YY starts with 2-9"
    fi
    
    # Extract month part for sanity check
    local month="${version#*.}"
    
    # Basic sanity check: month should be 05 or 11 for stable releases
    if [[ "$month" != "05" && "$month" != "11" ]]; then
        warn "⚠️  Warning: Stable NixOS releases typically use .05 (May) or .11 (November)"
        warn "    You specified: ${version}"
    fi
}

upgrade_nixos_version() {
    local new_version="$1"
    
    log "🔄 Upgrading NixOS to version ${BLUE}${new_version}${NC}..."
    
    # Validation
    validate_version "$new_version"
    
    # Backup of the current flake.nix
    log "📦 Backing up flake.nix..."
    cp flake.nix "flake.nix.backup-$(date +%Y%m%d-%H%M%S)"
    
    # The nixpkgs URL
    local nixpkgs_url="github:NixOS/nixpkgs/nixos-${new_version}"
    log "📝 Updating flake.nix nixpkgs input to: ${nixpkgs_url}"
    
    # Method 1 : with sed (simple)
    if grep -q "nixpkgs.url.*github:NixOS/nixpkgs" flake.nix; then
        sed -i "s|nixpkgs\.url = \"github:NixOS/nixpkgs/nixos-[^\"]*\"|nixpkgs.url = \"${nixpkgs_url}\"|g" flake.nix
        log "✅ Updated nixpkgs URL in flake.nix"
    else
        warn "Could not automatically update flake.nix"
        echo ""
        echo "Please manually update your flake.nix:"
        echo "  inputs.nixpkgs.url = \"${nixpkgs_url}\";"
        echo ""
        read -p "Press Enter after manual update, or Ctrl+C to abort..."
    fi
    
    # Show the diff
    log "📋 Changes in flake.nix:"
    git diff flake.nix | head -20 || true
    
    # Confirmation message
    echo ""
    warn "⚠️  You are about to upgrade to NixOS ${new_version}"
    warn "    This is a major change. Make sure you have backups!"
    echo ""
    read -p "Continue with upgrade? (yes/N) " -r
    if [[ ! $REPLY =~ ^[Yy][Ee][Ss]$ ]]; then
        log "❌ Upgrade cancelled"
        # Restore the backup
        mv flake.nix.backup-* flake.nix 2>/dev/null || true
        exit 0
    fi
    
    # Update flake.lock
    log "🔄 Updating flake.lock..."
    nix flake update || error "Failed to update flake"
    
    log "✅ NixOS version upgraded to ${new_version}"
    log "💡 Next: Run rebuild to build the new configuration"
}

show_flake_changes() {
    log "📋 Flake changes:"
    
    [[ -f flake.lock ]] && cp flake.lock flake.lock.backup

    nix flake update || error "❌ Flake update failed"
    
    if [[ -f flake.lock.backup ]]; then
        # git diff flake.lock | awk '/^[+-]/ && !/^(---|\+\+\+)/'
        git diff --no-color flake.lock.backup flake.lock | \
            awk '/^[+-]/ && !/^(---|\+\+\+)/' | \
            head -30
    fi
    
    rm -f flake.lock.backup
}


parse_args "$@"

# Check the flake directory
[[ ! -d "$FLAKE_DIR" ]] && error "Flake directory not found: $FLAKE_DIR"
cd "$FLAKE_DIR" || error "Cannot cd to $FLAKE_DIR"

# Check if the flake target exists
flake_target="$(nix flake show --json 2>/dev/null | jq -r --arg host "$HOSTNAME" '.nixosConfigurations | keys[] | select(contains($host))')"
if [ -z "$flake_target" ]; then
    error "Configuration '${HOSTNAME}' not found in flake!\nAvailable: $(nix flake show 2>/dev/null | awk '/nixosConfigurations/ { print $2 }' | sort)"
fi

log "🚀 NixOS Update Script"
log "🖥️  Current machine: ${YELLOW}${HOSTNAME_CURRENT}${NC}"
log "🎯  Target: ${BLUE}${HOSTNAME}${NC}"
log "🔍  Flake target: ${YELLOW}.#${flake_target}${NC}"
[[ "$UPGRADE_MODE" == true ]] && log "📦 Upgrade mode: ${BLUE}${NIXOS_VERSION}${NC}"

# Check for uncommitted changes
if [[ -n $(git status --porcelain 2>/dev/null) ]]; then
    warn "⚠️ Uncommitted changes detected"
    git status --short
    read -p "Continue anyway? (y/N) " -n 1 -r
    echo
    [[ ! $REPLY =~ ^[Yy]$ ]] && exit 0

    # Automatic backup
    log "📦 Creating backup commit..."
    git add . && git commit -m "Pre-update backup [${flake_target}] $(date +%Y-%m-%d_%H:%M)" || true
fi

# Upgrade mode
if [[ "$UPGRADE_MODE" == true ]]; then
    upgrade_nixos_version "$NIXOS_VERSION"
else
    # Normal update mode
    show_flake_changes
fi

# Build test
log "🔨 Building configuration for ${flake_target}..."
sudo nixos-rebuild build --flake "$flake_target" || error "❌ Build failed"

# Show the differences
log "📊 Computing differences..."
nix store diff-closures /run/current-system ./result | head -50

# Ask for confirmation
echo ""
echo -e "${YELLOW}═══════════════════════════════════════${NC}"
echo -e "${GREEN}Ready to apply changes to ${flake_target}${NC}"
echo -e "${YELLOW}═══════════════════════════════════════${NC}"
echo ""
echo "Options:"
echo -e "  ${GREEN}[b]${NC} boot   - Apply on next boot (${YELLOW}safest${NC})"
echo -e "  ${GREEN}[s]${NC} switch - Apply immediately"
echo -e "  ${GREEN}[t]${NC} test   - Apply temporarily (reverts on reboot)"
echo -e "  ${RED}[n]${NC} abort  - Cancel"
echo ""
read -p "Your choice: " -n 1 -r
echo

case $REPLY in
    b|B)
        log "🥾 Applying to boot..."
        sudo nixos-rebuild boot --flake "$flake_target" || error "Boot configuration failed"
        log "✅ Configuration will be active after reboot"
        [[ $NOTIFY == true ]] && notify-send "NixOS Updated" "Reboot ${flake_target} to apply changes"
        ;;
    s|S)
        log "⚡ Switching immediately..."
        sudo nixos-rebuild switch --flake "$flake_target" || error "Switch failed"
        log "✅ System ${flake_target} updated successfully!"
        [[ $NOTIFY == true ]] && notify-send "NixOS Updated" "${flake_target} updated successfully"
        # Post-update checks
        log "🔍 Verifying system state..."
        if systemctl --failed --no-pager | grep -q 'failed'; then
            warn "⚠️  Some services failed to start"
            systemctl --failed --no-pager
        else
            log "✅ All services running correctly"
        fi
        ;;
    t|T)
        log "🧪 Testing configuration..."
        sudo nixos-rebuild test --flake "$flake_target" || error "Test failed"
        log "✅ Configuration tested (temporary, will revert on reboot)"
        ;;
    *)
        log "❌ Update cancelled"
        exit 0
        ;;
esac

# Optional cleanup
echo ""
read -p "Run garbage collection? (y/N) " -n 1 -r
echo
if [[ $REPLY =~ ^[Yy]$ ]]; then
    log "🗑️  Running garbage collection..."
    sudo nix-collect-garbage --delete-older-than 30d
    log "🧹 Old generations cleaned"
fi

# Commit
if [[ -n $(git status --porcelain) ]]; then
    log "💾 Committing changes..."
    git add flake.lock flake.nix
    local commit_msg="Update NixOS [${HOSTNAME}] $(date +%Y-%m-%d)"
    [[ "$UPGRADE_MODE" == true ]] && commit_msg="Upgrade to NixOS ${NIXOS_VERSION} [${HOSTNAME}] $(date +%Y-%m-%d)"
    git commit -m "$commit_msg" || true
fi

log "🎉 Update process completed!"
